# Backend
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0

# Frontend
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:4000

# ROS Plugin
ROBOT_ID=robot-1
BACKEND_WS_URL=ws://127.0.0.1:4000/ws/plugin

# Provided ROS Simulation via rosbridge
# The provided web-ros compose uses host networking.
# On Docker Desktop Mac, the ROS Plugin also runs with network_mode: host,
# so it connects to rosbridge through 127.0.0.1:9090.
ROSBRIDGE_HOST=127.0.0.1
ROSBRIDGE_PORT=9090
